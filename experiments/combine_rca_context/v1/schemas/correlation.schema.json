{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Correlation Timeline",
  "description": "Correlation between AAP job and Splunk logs",
  "type": "object",
  "required": ["job_id", "correlation", "timeline_events"],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "time_range": {
      "type": "object",
      "properties": {
        "start": {"type": "string"},
        "end": {"type": "string"},
        "duration_seconds": {"type": "number"}
      }
    },
    "correlation": {
      "type": "object",
      "required": ["method", "confidence"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["namespace_time_match", "guid_time_match", "pod_name_match", "identifier_match", "none"],
          "description": "How correlation was established"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "none"]
        },
        "identifiers": {
          "type": "object",
          "properties": {
            "guid": {"type": ["string", "null"]},
            "namespace": {"type": ["string", "null"]}
          }
        },
        "time_overlap": {
          "type": "object",
          "properties": {
            "aap_job_start": {"type": "string"},
            "aap_job_end": {"type": "string"},
            "splunk_first_log": {"type": ["string", "null"]},
            "splunk_last_log": {"type": ["string", "null"]},
            "overlap_confirmed": {"type": "boolean"}
          }
        },
        "matching_pods": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "timeline_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "source", "event_type", "summary"],
        "properties": {
          "timestamp": {"type": "string"},
          "source": {
            "type": "string",
            "enum": ["aap_job", "splunk_ocp"]
          },
          "event_type": {
            "type": "string",
            "enum": ["task_failed", "pod_error", "warning", "info"]
          },
          "summary": {"type": "string"},
          "details": {"type": "object"}
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "aap_failed_tasks": {"type": "integer"},
        "splunk_error_logs": {"type": "integer"},
        "total_timeline_events": {"type": "integer"},
        "pods_involved": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
