{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Analysis Summary",
  "description": "Root cause summary from correlation analysis with AgnosticD/V configuration context",
  "type": "object",
  "required": ["job_id", "root_cause", "correlation", "evidence"],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "analyzed_at": {
      "type": "string",
      "format": "date-time"
    },
    "job_metadata": {
      "type": "object",
      "description": "Parsed job metadata for AgnosticD/V context",
      "properties": {
        "platform": {"type": "string"},
        "catalog_item": {"type": "string"},
        "environment": {"type": "string"},
        "guid": {"type": "string"},
        "namespace": {"type": "string"}
      }
    },
    "failed_tasks": {
      "type": "array",
      "description": "Complete details of failed tasks from AAP job log (preserves all original fields)",
      "items": {
        "type": "object",
        "required": ["task", "error_message"],
        "properties": {
          "task": {
            "type": "string",
            "description": "Task name"
          },
          "play": {
            "type": "string",
            "description": "Play name from AAP job"
          },
          "role": {
            "type": "string",
            "description": "Role name from AAP job"
          },
          "timestamp": {
            "type": "string",
            "description": "When the task failed"
          },
          "error_message": {
            "type": "string",
            "description": "Error message from the failed task"
          },
          "task_action": {
            "type": "string",
            "description": "Ansible module used (e.g., kubernetes.core.k8s_info)"
          },
          "duration": {
            "type": "number",
            "description": "Task execution duration in seconds"
          },
          "location": {
            "type": "object",
            "description": "Task location information",
            "properties": {
              "original_path": {
                "type": "string",
                "description": "Original task_path from AAP event (e.g., /home/runner/.ansible/collections/ansible_collections/agnosticd/core_workloads/roles/ROLE/tasks/FILE.yml:LINE)"
              },
              "repository": {
                "type": "string",
                "description": "GitHub repository (e.g., agnosticd/core_workloads or redhat-cop/agnosticd)"
              },
              "file_path": {
                "type": "string",
                "description": "Path within repository (e.g., roles/ROLE/tasks/FILE.yml)"
              },
              "line_number": {
                "type": "integer",
                "description": "Line number in the file"
              },
              "github_path": {
                "type": "string",
                "description": "Full GitHub reference (e.g., agnosticd/core_workloads:roles/ROLE/tasks/FILE.yml:LINE)"
              }
            }
          }
        }
      }
    },
    "agnosticv_config": {
      "type": "object",
      "description": "AgnosticV configuration hierarchy",
      "properties": {
        "hierarchy": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "file": {"type": "string"},
              "url": {"type": "string"},
              "relevant_vars": {"type": "object"},
              "missing_vars": {
                "type": "array",
                "items": {"type": "string"}
              },
              "secrets_referenced": {
                "type": "array",
                "items": {"type": "string"}
              },
              "vault_encrypted_vars": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "agnosticd_workloads": {
      "type": "array",
      "description": "AgnosticD workload/role details for failed tasks",
      "items": {
        "type": "object",
        "properties": {
          "role": {"type": "string"},
          "task_file": {"type": "string"},
          "task_line": {"type": "number"},
          "task_action": {"type": "string"},
          "github_url": {"type": "string"}
        }
      }
    },
    "root_cause": {
      "type": "object",
      "required": ["summary", "category", "confidence"],
      "properties": {
        "summary": {
          "type": "string",
          "description": "One-line description of the root cause"
        },
        "category": {
          "type": "string",
          "enum": [
            "application_bug",
            "infrastructure",
            "configuration",
            "dependency",
            "network",
            "resource",
            "cloud_api",
            "secrets",
            "unknown"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    },
    "correlation": {
      "type": "object",
      "required": ["method", "identifiers"],
      "properties": {
        "method": {
          "type": "string",
          "description": "How AAP job was correlated to Splunk logs"
        },
        "identifiers": {
          "type": "object",
          "properties": {
            "guid": {"type": "string"},
            "namespace": {"type": "string"},
            "pod_name": {"type": "string"}
          }
        },
        "time_overlap": {
          "type": "object",
          "properties": {
            "aap_job_start": {"type": "string"},
            "aap_job_end": {"type": "string"},
            "splunk_first_error": {"type": "string"},
            "splunk_last_error": {"type": "string"},
            "overlap_confirmed": {"type": "boolean"}
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source", "timestamp", "message"],
        "properties": {
          "source": {
            "type": "string",
            "enum": ["aap_job", "splunk_ocp", "agnosticv_config", "agnosticd_code"]
          },
          "timestamp": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "action": {"type": "string"},
          "file": {"type": "string"},
          "github_url": {"type": "string"},
          "change": {"type": "string"},
          "details": {"type": "string"}
        }
      }
    },
    "contributing_factors": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
